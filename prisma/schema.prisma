generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  keys     Key[]
  otps     OTP[]
}

model Key {
  id        String @id
  publicKey String
  counter   Int
  name      String
  user      User   @relation(fields: [userId], references: [id])
  userId    Int
}

model OTP {
  id       String  @id @default(cuid())
  secret   String
  lastUsed String?
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}
